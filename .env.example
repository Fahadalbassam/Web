MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/carparts_catalog?appName=CarPart

# URL the Next.js server uses to call PHP (RSC / must match `next.config` rewrite target).
PHP_BACKEND_URL=http://127.0.0.1:8080

# Optional — `scripts/seed-admins.mjs` only (Node dev tool, not production auth).
ADMIN_SEED_PASSWORD_FAHAD=
ADMIN_SEED_PASSWORD_OBAI=

# Local dev: `npm run dev:full` starts Next + PHP. PHP CLI path is pinned in package.json (Windows XAMPP).
